# Copy this file to .env before deployment.
# For local docker-compose you can keep defaults.
# For Railway + TiDB, override DB_HOST/DB_PORT/DB_USER/DB_PASSWORD in service env vars.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_NAME=dataflow_digram
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Frontend origins allowed to call API (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,null

# Optional regex for dynamic front-end origins (useful for pages.dev preview domains)
# Example: https://.*\.pages\.dev
CORS_ALLOW_ORIGIN_REGEX=

# Cookie/session options (safe local defaults)
AUTH_COOKIE_NAME=df_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# Database TLS options (needed for TiDB public endpoint)
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
DB_SSL_DISABLED=false
DB_SSL_VERIFY_CERT=false
DB_SSL_VERIFY_IDENTITY=false

# Initial admin account (used only when users table is empty)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Production overrides for Netlify + Railway + TiDB deployment ---
# Frontend: Netlify
# Backend: Railway (Docker)
# Database: TiDB Cloud
#
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=none
# CORS_ALLOW_ORIGINS=https://<your-netlify-site>.netlify.app
# DB_PORT=4000
# DB_SSL_VERIFY_CERT=true
# DB_SSL_VERIFY_IDENTITY=true
